NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Service role key — server-side only (cron routes, never exposed to browser)
# Found in Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Protects the cron endpoint from unauthorized calls
CRON_SECRET=generate-a-random-string-here

# Data source for nightly batch (Phase 2 — leave blank for now)
PUNTING_FORM_API_KEY=
