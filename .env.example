# The Odds API — https://the-odds-api.com
ODDS_API_KEY=
ODDS_API_BOOKMAKERS=tab,sportsbet   # comma-separated; fewer = less quota used
ODDS_API_REGIONS=au

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Punting Form API (Phase 2 — leave blank for Phase 1)
PUNTING_FORM_API_KEY=

# Pipeline settings
LIVE_POLL_INTERVAL_SECONDS=60
LIVE_POLL_NEAR_JUMP_SECONDS=15
LIVE_POLL_NEAR_JUMP_WINDOW_MINUTES=10
NIGHTLY_BATCH_HOUR_AEST=18

# App
APP_ENV=development
LOG_LEVEL=INFO
