# Betfair credentials (Betfair Exchange account required)
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_CERT_PATH=./certs/betfair.crt
BETFAIR_KEY_PATH=./certs/betfair.key

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Punting Form API (Phase 2 — leave blank for Phase 1)
PUNTING_FORM_API_KEY=

# Pipeline settings
LIVE_POLL_INTERVAL_SECONDS=60      # tightens to 15s within 10 min of jump
LIVE_POLL_NEAR_JUMP_SECONDS=15
LIVE_POLL_NEAR_JUMP_WINDOW_MINUTES=10
NIGHTLY_BATCH_HOUR_AEST=18         # 6pm AEST — after fields confirmed

# App
APP_ENV=development                # development | production
LOG_LEVEL=INFO
